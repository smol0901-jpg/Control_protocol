
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="NAP Control Protocol — автономная система очистки и оптимизации среды разработки. Премиум-релиз v8.3."/>
  <meta name="theme-color" content="#0b0b14"/>
  <title>NAP Control Protocol | DevCleaner Pro v8.3</title>
  
  <style>
    /* ===== DESIGN TOKENS — Clean & Calm ===== */
    :root{
      /* Colors — Soft, professional, non-aggressive */
      --bg-base: #0b0b14;
      --bg-surface: #141424;
      --bg-card: #1a1a2e;
      --text-primary: #f5f5ff;
      --text-secondary: #b8b8d9;
      --text-muted: #7a7a9a;
      --accent: #7c83fd;
      --accent-soft: rgba(124, 131, 253, 0.15);
      --border: rgba(140, 150, 200, 0.18);
      --border-hover: rgba(140, 150, 200, 0.35);
      --shadow-soft: 0 8px 32px rgba(0, 0, 0, 0.35);
      --shadow-subtle: 0 4px 16px rgba(0, 0, 0, 0.25);
      
      /* Spacing — 8px grid system */
      --space-1: 0.25rem; --space-2: 0.5rem; --space-3: 0.75rem;
      --space-4: 1rem; --space-5: 1.5rem; --space-6: 2rem;
      --space-7: 3rem; --space-8: 4rem; --space-9: 6rem;
      
      /* Typography */
      --font-main: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
      --text-xs: 0.75rem; --text-sm: 0.875rem; --text-base: 1rem;
      --text-lg: 1.125rem; --text-xl: 1.25rem; --text-2xl: 1.5rem;
      --text-3xl: 2rem; --text-4xl: 2.5rem; --text-5xl: 3.5rem;
      
      /* Radius & Transitions */
      --radius-sm: 10px; --radius-md: 16px; --radius-lg: 24px;
      --transition: 250ms cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    /* ===== RESET & BASE ===== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body{
      font-family: var(--font-main);
      background: var(--bg-base);
      color: var(--text-primary);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }
    
    /* ===== HIGH-DPI SUPPORT ===== */
    @media (-webkit-min-device-pixel-ratio: 2), (min-resolution: 192dpi) {
      body { image-rendering: -webkit-optimize-contrast; }
    }
    
    /* ===== SUBTLE PARALLAX — 4 Layers, Calm ===== */
    .parallax{
      position: fixed; inset: 0; pointer-events: none; z-index: -1;
      transform-style: preserve-3d;
    }
    .parallax__layer{
      position: absolute; inset: 0; background-size: cover; background-position: center;
      will-change: transform; transition: transform 0.1s linear;
    }
    .layer-1{ /* Deep background */
      background: radial-gradient(1000px 500px at 20% -10%, rgba(124,131,253,0.06), transparent 60%),
                  radial-gradient(800px 400px at 80% 110%, rgba(124,131,253,0.04), transparent 55%),
                  linear-gradient(180deg, var(--bg-base) 0%, #0e0e1a 50%, var(--bg-base) 100%);
      transform: translateZ(-3px) scale(3);
    }
    .layer-2{ /* Subtle grid */
      background-image:
        linear-gradient(rgba(140,150,200,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(140,150,200,0.03) 1px, transparent 1px);
      background-size: 80px 80px;
      transform: translateZ(-2px) scale(2.2);
      opacity: 0.6;
    }
    .layer-3{ /* Soft nodes */
      background: transparent;
      transform: translateZ(-1px) scale(1.6);
    }
    .layer-4{ /* Gentle glow */
      background: radial-gradient(500px 250px at 30% 70%, rgba(124,131,253,0.05), transparent 70%);
      transform: translateZ(-0.5px) scale(1.3);
      animation: glowGentle 16s ease-in-out infinite;
    }
    @keyframes glowGentle{
      0%, 100% { opacity: 0.5; }
      50% { opacity: 0.75; }
    }
    
    /* ===== PARTICLES — Minimal & Crisp ===== */
    #particles{
      position: fixed; inset: 0; z-index: -1; pointer-events: none;
    }
    .particle{
      position: absolute; border-radius: 50%;
      background: radial-gradient(circle, rgba(255,255,255,0.95), rgba(124,131,253,0.4));
      box-shadow: 0 0 8px rgba(124,131,253,0.3);
      will-change: transform;
    }
    
    /* ===== LAYOUT — Symmetrical & Centered ===== */
    .wrapper{
      position: relative; z-index: 10;
      min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center;
    }
    
    /* ===== HEADER — Clean & Balanced ===== */
    .header{
      position: sticky; top: 0; z-index: 100;
      width: 100%; max-width: 1200px;
      padding: var(--space-4) var(--space-5);
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(11, 11, 20, 0.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      transition: all var(--transition);
    }
    .header.scrolled { padding: var(--space-3) var(--space-5); }
    
    .logo{
      display: flex; align-items: center; gap: var(--space-3);
      text-decoration: none; color: inherit;
    }
    .logo__icon{
      width: 32px; height: 32px; border-radius: 8px;
      background: linear-gradient(135deg, var(--accent), #9a9ffd);
      display: grid; place-items: center;
      font-weight: 700; font-size: 0.9rem; color: #fff;
      box-shadow: 0 4px 12px rgba(124,131,253,0.3);
    }
    .logo__text{ font-weight: 600; font-size: var(--text-lg); letter-spacing: -0.01em; }
    .logo__badge{
      font-size: var(--text-xs); padding: 2px 8px;
      background: var(--accent-soft); border: 1px solid var(--border);
      border-radius: 6px; color: var(--accent); font-weight: 500;
    }
    
    .nav{ display: flex; gap: var(--space-2); }
    .nav__link{
      padding: var(--space-2) var(--space-3);
      border-radius: var(--radius-sm);
      color: var(--text-secondary); text-decoration: none;
      font-size: var(--text-sm); font-weight: 500;
      transition: all var(--transition);
    }
    .nav__link:hover, .nav__link.active{
      color: var(--text-primary); background: var(--accent-soft);
    }
    
    /* ===== HERO — Centered & Harmonious ===== */
    .hero{
      flex: 1; display: flex; align-items: center; justify-content: center;
      padding: var(--space-8) var(--space-5) var(--space-7);
      width: 100%; max-width: 1200px;
    }
    .hero__content{
      text-align: center; max-width: 720px; width: 100%;
      animation: fadeIn 0.7s ease-out both;
    }
    @keyframes fadeIn{
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .hero__badge{
      display: inline-flex; align-items: center; gap: var(--space-2);
      padding: 6px 14px; border-radius: 999px;
      background: var(--accent-soft); border: 1px solid var(--border);
      font-size: var(--text-sm); font-weight: 500; color: var(--text-secondary);
      margin-bottom: var(--space-5);
    }
    
    .hero__title{
      font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));
      font-weight: 700; line-height: 1.1; margin-bottom: var(--space-4);
      letter-spacing: -0.02em;
      background: linear-gradient(135deg, var(--text-primary) 0%, #c8cbff 50%, var(--accent) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .hero__subtitle{
      font-size: var(--text-lg); color: var(--text-secondary);
      max-width: 580px; margin: 0 auto var(--space-6);
      font-weight: 400; line-height: 1.55;
    }
    
    /* ===== FEATURES — EXACT 2×2 GRID, SYMMETRICAL ===== */
    .features{
      display: grid;
      grid-template-columns: repeat(2, 1fr); /* Exactly 2 columns */
      gap: var(--space-5);
      width: 100%; max-width: 720px; margin: 0 auto;
    }
    .feature{
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: var(--space-5);
      text-align: left;
      transition: all var(--transition);
      display: flex; flex-direction: column; gap: var(--space-3);
    }
    .feature:hover{
      border-color: var(--border-hover);
      transform: translateY(-3px);
      box-shadow: var(--shadow-subtle);
    }
    
    .feature__icon{
      width: 40px; height: 40px; border-radius: 10px;
      background: var(--accent-soft);
      display: grid; place-items: center;
      font-size: 1.2rem; flex-shrink: 0;
    }
    .feature__title{
      font-size: var(--text-base); font-weight: 600; color: var(--text-primary);
    }
    .feature__desc{
      font-size: var(--text-sm); color: var(--text-muted);
      line-height: 1.5;
    }
    
    /* ===== CTA — Balanced Buttons ===== */
    .cta{
      display: flex; gap: var(--space-3); justify-content: center;
      margin-top: var(--space-7); flex-wrap: wrap;
    }
    .btn{
      padding: 12px 28px; border-radius: 999px;
      font-weight: 600; font-size: var(--text-sm);
      text-decoration: none; display: inline-flex;
      align-items: center; gap: var(--space-2);
      transition: all var(--transition); border: none; cursor: pointer;
    }
    .btn--primary{
      background: linear-gradient(135deg, var(--accent), #9a9ffd);
      color: #fff; box-shadow: 0 6px 20px rgba(124,131,253,0.35);
    }
    .btn--primary:hover{
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(124,131,253,0.5);
    }
    .btn--secondary{
      background: transparent; color: var(--text-primary);
      border: 1px solid var(--border);
    }
    .btn--secondary:hover{
      background: var(--accent-soft); border-color: var(--border-hover);
      transform: translateY(-2px);
    }
    
    /* ===== ROLES — Clean Tags ===== */
    .roles{
      display: flex; flex-wrap: wrap; justify-content: center; gap: var(--space-2);
      margin-top: var(--space-6); padding-top: var(--space-5);
      border-top: 1px dashed var(--border);
    }
    .role{
      padding: 4px 10px; border-radius: 6px;
      background: rgba(140,150,200,0.08);
      border: 1px solid var(--border);
      font-size: var(--text-xs); color: var(--text-muted);
      font-weight: 500; transition: all var(--transition);
    }
    .role:hover{
      background: var(--accent-soft); color: var(--text-secondary);
      transform: translateY(-1px);
    }
    
    /* ===== FOOTER — Minimal & Centered ===== */
    .footer{
      padding: var(--space-5) var(--space-4);
      text-align: center; color: var(--text-muted);
      font-size: var(--text-sm); border-top: 1px solid var(--border);
      width: 100%; max-width: 1200px;
    }
    .footer a{ color: var(--accent); text-decoration: none; transition: color var(--transition); }
    .footer a:hover{ color: var(--text-primary); }
    .footer__meta{
      margin-top: var(--space-2); font-size: var(--text-xs);
      font-family: var(--font-mono); opacity: 0.9;
    }
    
    /* ===== ACCESSIBILITY ===== */
    :focus-visible{
      outline: 2px solid var(--accent); outline-offset: 2px;
      border-radius: 4px;
    }
    @media (prefers-reduced-motion: reduce){
      *, *::before, *::after{
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }
    
    /* ===== RESPONSIVE — Symmetrical on all screens ===== */
    @media (max-width: 768px){
      .features{ grid-template-columns: 1fr; } /* Stack on mobile */
      .hero{ padding: var(--space-6) var(--space-4) var(--space-5); }
      .header{ padding: var(--space-3) var(--space-4); }
      .cta{ flex-direction: column; align-items: center; }
      .btn{ width: 100%; max-width: 280px; justify-content: center; }
    }
    
    /* ===== PRINT — Crisp output ===== */
    @media print{
      .parallax, #particles{ display: none; }
      body{ background: #fff; color: #000; }
      .feature{ break-inside: avoid; border: 1px solid #ccc; }
    }
  </style>
</head>
<body>
  <!-- ===== PARALLAX LAYERS (Subtle, 4 layers) ===== -->
  <div class="parallax" aria-hidden="true">
    <div class="parallax__layer layer-1"></div>
    <div class="parallax__layer layer-2"></div>
    <div class="parallax__layer layer-3" id="node-layer"></div>
    <div class="parallax__layer layer-4"></div>
  </div>
  <canvas id="particles"></canvas>
  
  <!-- ===== MAIN CONTENT ===== -->
  <div class="wrapper">
    <!-- Header -->
    <header class="header">
      <a href="#" class="logo">
        <div class="logo__icon">N</div>
        <span class="logo__text">NAP Protocol</span>
        <span class="logo__badge">v8.3</span>
      </a>
      <nav class="nav">
        <a href="#features" class="nav__link active">Возможности</a>
        <a href="https://github.com/smol0901-jpg/Control_protocol/releases/tag/NAP_Control_protocol" class="nav__link" target="_blank" rel="noopener">Релиз</a>
        <a href="https://github.com/smol0901-jpg/Control_protocol" class="nav__link" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </header>
    
    <!-- Hero + Features (2×2 Grid) -->
    <main class="hero">
      <div class="hero__content">
        <div class="hero__badge">✨ DevCleaner Pro • Премиум</div>
        <h1 class="hero__title">NAP Control Protocol</h1>
        <p class="hero__subtitle">Автономный интеллект для очистки и оптимизации среды разработки. Умный мониторинг • Машинное обучение • Мгновенные отчёты</p>
        
        <!-- EXACT 2×2 GRID — Symmetrical & Harmonious -->
        <div class="features" id="features">
          <article class="feature">
            <div class="feature__icon">🧠</div>
            <h3 class="feature__title">ML-анализ процессов</h3>
            <p class="feature__desc">Random Forest предсказывает безопасные для завершения процессы на основе 50+ метрик</p>
          </article>
          <article class="feature">
            <div class="feature__icon">⚡</div>
            <h3 class="feature__title">Авто-очистка кэшей</h3>
            <p class="feature__desc">npm, pip, Gradle, VS Code — интеллектуальное освобождение места без риска</p>
          </article>
          <article class="feature">
            <div class="feature__icon">📊</div>
            <h3 class="feature__title">PDF-отчёты Pro</h3>
            <p class="feature__desc">Профессиональные дашборды с графиками, рекомендациями и историей оптимизаций</p>
          </article>
          <article class="feature">
            <div class="feature__icon">🔌</div>
            <h3 class="feature__title">REST API v2</h3>
            <p class="feature__desc">Удалённое управление через защищённый HTTP-интерфейс с JWT-аутентификацией</p>
          </article>
        </div>
        
        <!-- CTA Buttons -->
        <div class="cta">
          <a href="https://github.com/smol0901-jpg/Control_protocol/releases/tag/NAP_Control_protocol" class="btn btn--primary" target="_blank" rel="noopener">⬇️ Скачать релиз</a>
          <a href="https://github.com/smol0901-jpg/Control_protocol" class="btn btn--secondary" target="_blank" rel="noopener">📁 Исходный код</a>
        </div>
        
        <!-- Team Roles (Clean Tags) -->
        <div class="roles">
          <span class="role">UI/UX</span>
          <span class="role">Frontend</span>
          <span class="role">Backend</span>
          <span class="role">Analyst</span>
          <span class="role">QA</span>
          <span class="role">SEO</span>
          <span class="role">Copy</span>
          <span class="role">Content</span>
          <span class="role">PM</span>
          <span class="role">DevOps</span>
        </div>
      </div>
    </main>
    
    <!-- Footer -->
    <footer class="footer">
      <p>© 2026 <strong>NAP Protocol</strong> • Автор: <a href="https://vk.com/smolyaninovchef" target="_blank" rel="noopener">Смолянинов Александр</a></p>
      <p class="footer__meta">DevCleaner Pro • Windows • Python 3.10+ • MIT License</p>
    </footer>
  </div>
  
  <!-- ===== PHYSICS ENGINE — Crisp & Subtle ===== -->
  <script>
    (function(){
      'use strict';
      
      // Config — Calm & Performant
      const CFG = {
        particleCount: Math.min(35, Math.floor(window.innerWidth / 30)),
        particleSize: {min: 1, max: 3},
        particleSpeed: {min: 0.15, max: 0.4},
        connectionDist: 100,
        mouseRadius: 120,
        parallaxSpeed: [0.08, 0.14, 0.22, 0.35],
        colors: ['rgba(124,131,253,0.9)', 'rgba(154,159,253,0.85)', 'rgba(200,205,255,0.8)']
      };
      
      const state = {
        particles: [], mouse: {x: null, y: null},
        canvas: null, ctx: null,
        dpr: Math.min(2, window.devicePixelRatio || 1),
        w: 0, h: 0, last: 0
      };
      
      const U = {
        rand: (min, max) => Math.random() * (max - min) + min,
        dist: (x1,y1,x2,y2) => Math.hypot(x2-x1, y2-y1),
        throttle: (fn, ms) => {
          let t = 0; return (...a) => {
            const now = Date.now();
            if(now - t >= ms){ t = now; fn.apply(this, a); }
          };
        }
      };
      
      class Particle{
        constructor(x, y){
          this.x = x ?? U.rand(0, state.w);
          this.y = y ?? U.rand(0, state.h);
          this.vx = U.rand(-0.2, 0.2); this.vy = U.rand(-0.2, 0.2);
          this.size = U.rand(CFG.particleSize.min, CFG.particleSize.max);
          this.speed = U.rand(CFG.particleSpeed.min, CFG.particleSpeed.max);
          this.color = CFG.colors[Math.floor(U.rand(0, CFG.colors.length))];
        }
        update(dt){
          if(state.mouse.x !== null){
            const dx = state.mouse.x - this.x, dy = state.mouse.y - this.y;
            const d = Math.hypot(dx, dy);
            if(d < CFG.mouseRadius && d > 8){
              const f = (CFG.mouseRadius - d) / CFG.mouseRadius * 0.015;
              this.vx += (dx/d) * f; this.vy += (dy/d) * f;
            }
          }
          this.x += this.vx * this.speed * dt;
          this.y += this.vy * this.speed * dt;
          this.vx *= 0.998; this.vy *= 0.998;
          if(this.x < -10) this.x = state.w + 10;
          if(this.x > state.w + 10) this.x = -10;
          if(this.y < -10) this.y = state.h + 10;
          if(this.y > state.h + 10) this.y = -10;
        }
        draw(ctx){
          ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI*2);
          ctx.fillStyle = this.color; ctx.fill();
        }
      }
      
      function drawLinks(ctx, particles){
        ctx.strokeStyle = 'rgba(140,150,200,0.12)'; ctx.lineWidth = 0.5;
        for(let i=0; i<particles.length; i++){
          for(let j=i+1; j<particles.length; j++){
            const p1=particles[i], p2=particles[j];
            const d = U.dist(p1.x,p1.y, p2.x,p2.y);
            if(d < CFG.connectionDist){
              ctx.globalAlpha = (1 - d/CFG.connectionDist) * 0.3;
              ctx.beginPath(); ctx.moveTo(p1.x,p1.y); ctx.lineTo(p2.x,p2.y); ctx.stroke();
            }
          }
        }
        ctx.globalAlpha = 1;
      }
      
      function setupCanvas(){
        state.canvas = document.getElementById('particles');
        state.ctx = state.canvas.getContext('2d', {alpha:true, desynchronized:true});
        resize();
        window.addEventListener('resize', U.throttle(resize, 200));
      }
      
      function resize(){
        state.w = window.innerWidth; state.h = window.innerHeight;
        state.canvas.width = state.w * state.dpr;
        state.canvas.height = state.h * state.dpr;
        state.canvas.style.width = state.w+'px'; state.canvas.style.height = state.h+'px';
        state.ctx.scale(state.dpr, state.dpr);
        initParticles(true);
      }
      
      function initParticles(force){
        if(force || !state.particles.length){
          state.particles = [];
          for(let i=0; i<CFG.particleCount; i++) state.particles.push(new Particle());
        }
      }
      
      function loop(ts){
        const dt = Math.min(2, (ts - state.last) / 16.67); state.last = ts;
        const ctx = state.ctx; ctx.clearRect(0,0,state.w,state.h);
        state.particles.forEach(p => { p.update(dt); p.draw(ctx); });
        drawLinks(ctx, state.particles);
        while(state.particles.length < CFG.particleCount) state.particles.push(new Particle());
        requestAnimationFrame(loop);
      }
      
      function initParallax(){
        const layers = document.querySelectorAll('.parallax__layer');
        const onScroll = U.throttle(() => {
          const y = window.pageYOffset;
          layers.forEach((l, i) => {
            l.style.transform = `translate3d(0, ${y * CFG.parallaxSpeed[i]}px, 0) scale(${1 + i*0.3})`;
          });
        }, 16);
        window.addEventListener('scroll', onScroll, {passive:true});
        onScroll();
      }
      
      function initMouse(){
        const onMove = U.throttle(e => {
          state.mouse.x = e.clientX; state.mouse.y = e.clientY;
        }, 40);
        window.addEventListener('mousemove', onMove, {passive:true});
        window.addEventListener('mouseleave', () => { state.mouse.x = state.mouse.y = null; });
      }
      
      function initHeader(){
        const h = document.querySelector('.header');
        const onScroll = U.throttle(() => {
          h.classList.toggle('scrolled', window.scrollY > 40);
        }, 100);
        window.addEventListener('scroll', onScroll, {passive:true});
      }
      
      function init(){
        setupCanvas(); initParallax(); initMouse(); initParticles(); initHeader();
        requestAnimationFrame(loop);
        // Smooth reveal
        const content = document.querySelector('.hero__content');
        if(content){ content.style.opacity='0'; content.style.transform='translateY(12px)';
          setTimeout(()=>{ content.style.transition='opacity 0.6s ease, transform 0.6s ease';
            content.style.opacity='1'; content.style.transform='translateY(0)'; }, 150);
        }
      }
      
      document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', init) : init();
    })();
  </script>
</body>
</html>
